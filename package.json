{
  "name": "ddm-wigs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "start": "wrangler pages dev ./build/client",
    "deploy": "npm run build && node scripts/build-worker.mjs && wrangler pages deploy ./build/client --project-name ddm-wigs",
    "typecheck": "tsc",
    "db:migrate": "wrangler d1 execute ddm-wigs-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute ddm-wigs-db --local --file=./migrations/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@remix-run/dev": "^2.17.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.105.0"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.17.5",
    "@remix-run/cloudflare-pages": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "isbot": "^5.1.44",
    "mimetext": "^3.0.28",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
