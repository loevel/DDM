{
  "name": "ddm-wigs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev public --port 3000",
    "deploy": "wrangler pages deploy public --project-name ddm-wigs",
    "db:create": "wrangler d1 create ddm-wigs-db",
    "db:migrate": "wrangler d1 execute ddm-wigs-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute ddm-wigs-db --local --file=./migrations/schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
