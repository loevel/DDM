{
  "name": "ddm-wigs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "start": "wrangler pages dev ./build/client",
    "deploy": "npm run build && node scripts/build-worker.mjs && wrangler pages deploy ./build/client --project-name ddm-wigs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "wrangler d1 execute ddm-wigs-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute ddm-wigs-db --local --file=./migrations/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@remix-run/dev": "^2.17.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.17.5",
    "@remix-run/cloudflare-pages": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "isbot": "^5.1.44",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.3.0"
  }
}
